# Kopieer dit bestand naar .env en vul de waarden in.
# .env staat in .gitignore en wordt nooit gecommit.

# --- PostgreSQL ---
POSTGRES_DB=anna_remembers
POSTGRES_USER=anna
POSTGRES_PASSWORD=verander_mij

# --- LLM Provider ---
# Opties: ollama | anthropic | openai
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://ollama:11434

# --- Docker Hub ---
# Alleen nodig als je lokaal images wil pushen.
# In CI/CD worden deze waarden via GitHub Secrets ingesteld.
DOCKERHUB_USERNAME=jouw-gebruikersnaam
DOCKERHUB_TOKEN=dckr_pat_...
