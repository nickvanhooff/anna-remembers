# Kopieer dit bestand naar .env en vul de waarden in.
# .env staat in .gitignore en wordt nooit gecommit.

# --- PostgreSQL ---
POSTGRES_DB=anna_remembers
POSTGRES_USER=anna
POSTGRES_PASSWORD=verander_mij

# --- LLM Provider ---
# Opties: ollama | anthropic
LLM_PROVIDER=ollama

# OpenRouter (aanbevolen — één account, toegang tot Claude/GPT/Gemini/Llama)
# API key aanmaken via https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Anthropic direct (alternatief — API key via https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (lokaal)
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3

# --- Escalatie (Laag 1 — lokaal via Ollama) ---
# Pull eenmalig: docker exec -it anna_remembers-ollama-1 ollama pull qwen2.5:0.5b
ESCALATION_MODEL=qwen2.5:0.5b
# Minuten tussen escalaties per patiënt; zet op 0 om cooldown uit te zetten (testen)
ESCALATION_COOLDOWN_MINUTES=1

# --- Piper TTS ---
PIPER_URL=http://piper-tts:5000

# --- Docker Hub ---
# Alleen nodig als je lokaal images wil pushen.
# In CI/CD worden deze waarden via GitHub Secrets ingesteld.
DOCKERHUB_USERNAME=jouw-gebruikersnaam
DOCKERHUB_TOKEN=dckr_pat_...
