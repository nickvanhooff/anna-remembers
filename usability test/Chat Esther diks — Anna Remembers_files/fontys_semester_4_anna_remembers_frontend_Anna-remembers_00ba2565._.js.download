        patient: e.patient_id,
        name: e.patient_name,
        urgency: URGENCY_MAP[e.urgency],
        status: STATUS_MAP[e.status],
        reason: e.reason,
        channel: CHANNEL_MAP[e.urgency],
        assignee: null,
