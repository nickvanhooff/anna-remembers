    if (input.dob !== undefined) body.birth_date = input.dob || null;
    if (input.meds !== undefined) body.medication_schedule = input.meds ? {
        tekst: input.meds
    } : {};
    if (input.notes !== undefined) body.notes = input.notes || null;
